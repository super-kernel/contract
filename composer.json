{
    "name": "super-kernel/contract",
    "description": "Contracts and shared interfaces for the SuperKernel framework.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "super-kernel",
        "contract",
        "interfaces"
    ],
    "homepage": "https://github.com/super-kernel/contract",
    "support": {
        "issues": "https://github.com/super-kernel/contract/issues",
        "source": "https://github.com/super-kernel/contract"
    },
    "autoload": {
        "psr-4": {
            "SuperKernel\\Contract\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "psr/container": "^2.0",
        "psr/event-dispatcher": "^1.0",
        "psr/http-message": "^2.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "symfony/console": "^8.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}